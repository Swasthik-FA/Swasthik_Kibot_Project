#!/bin/bash
# =============================================================================
# Pre-push hook: PCB design validation (SOP-HW-002)
# Runs ERC, DRC, BOM export, and STM32 netlist validation before allowing push.
# Install: git config core.hooksPath hooks
# =============================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

KICAD_CLI=""
KICAD_SCH="design/pcb/kicad/Swasthik_KiBot_Project.kicad_sch"
KICAD_PCB="design/pcb/kicad/Swasthik_KiBot_Project.kicad_pcb"
REPORT_DIR="design/pcb/reports"
TEMP_DIR=".pre-push-checks"

# --- Find kicad-cli ---
find_kicad_cli() {
    # Check PATH first
    if command -v kicad-cli &>/dev/null; then
        KICAD_CLI="kicad-cli"
        return 0
    fi
    # Windows default paths
    for path in \
        "/c/Program Files/KiCad/9.0/bin/kicad-cli.exe" \
        "/c/Program Files/KiCad/8.0/bin/kicad-cli.exe" \
        "/c/Program Files/KiCad/bin/kicad-cli.exe" \
        "C:/Program Files/KiCad/9.0/bin/kicad-cli.exe" \
        "C:/Program Files/KiCad/8.0/bin/kicad-cli.exe"; do
        if [ -f "$path" ]; then
            KICAD_CLI="$path"
            return 0
        fi
    done
    return 1
}

# --- Check if schematic/PCB files changed ---
check_pcb_files_changed() {
    # Get the remote ref being pushed to
    local remote="$1"
    local url="$2"

    while read local_ref local_oid remote_ref remote_oid; do
        if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
            continue  # Branch deletion, skip
        fi
        # Check if any KiCad files changed in the commits being pushed
        if git diff --name-only "$remote_oid".."$local_oid" 2>/dev/null | grep -qE '\.(kicad_sch|kicad_pcb|kicad_pro)$'; then
            return 0  # PCB files changed
        fi
    done
    return 1  # No PCB files changed
}

# --- Main ---
echo -e "${YELLOW}=== Pre-push PCB validation (SOP-HW-002) ===${NC}"

# Skip if no schematic exists
if [ ! -f "$KICAD_SCH" ]; then
    echo -e "${YELLOW}No schematic found, skipping PCB checks.${NC}"
    exit 0
fi

# Find kicad-cli
if ! find_kicad_cli; then
    echo -e "${YELLOW}WARNING: kicad-cli not found. Skipping ERC/DRC/BOM checks.${NC}"
    echo -e "${YELLOW}Install KiCad or add kicad-cli to PATH.${NC}"
    # Still run netlist validation if netlist exists
    if [ -f design/pcb/outputs/*-netlist.net ]; then
        echo -e "${YELLOW}Running netlist validation on existing netlist...${NC}"
        python3 kibot_resources/scripts/validate_netlist.py \
            -n design/pcb/outputs/*-netlist.net \
            -o "$REPORT_DIR"
        echo -e "${GREEN}Netlist validation passed.${NC}"
    fi
    exit 0
fi

echo -e "Using kicad-cli: ${KICAD_CLI}"

# Create temp directory for reports
mkdir -p "$TEMP_DIR"

FAILED=0

# --- ERC ---
echo -e "\n${YELLOW}[1/4] Running ERC...${NC}"
"$KICAD_CLI" sch erc \
    --output "$TEMP_DIR/erc_report.rpt" \
    --exit-code-violations \
    "$KICAD_SCH" 2>/dev/null || true

if [ -f "$TEMP_DIR/erc_report.rpt" ]; then
    ERRORS=$(grep -oP 'Errors\s+\K[0-9]+' "$TEMP_DIR/erc_report.rpt" | head -1)
    WARNINGS=$(grep -oP 'Warnings\s+\K[0-9]+' "$TEMP_DIR/erc_report.rpt" | head -1)
    if [ "${ERRORS:-0}" -gt 0 ]; then
        echo -e "${RED}  FAIL: ERC found $ERRORS error(s)${NC}"
        FAILED=1
    else
        echo -e "${GREEN}  PASS: ERC (0 errors, ${WARNINGS:-0} warnings)${NC}"
    fi
else
    echo -e "${RED}  FAIL: ERC report not generated${NC}"
    FAILED=1
fi

# --- DRC ---
echo -e "\n${YELLOW}[2/4] Running DRC...${NC}"
"$KICAD_CLI" pcb drc \
    --output "$TEMP_DIR/drc_report.rpt" \
    --exit-code-violations \
    "$KICAD_PCB" 2>/dev/null || true

if [ -f "$TEMP_DIR/drc_report.rpt" ]; then
    UNCONNECTED=$(grep -oP 'Found\s+\K[0-9]+(?=\s+unconnected)' "$TEMP_DIR/drc_report.rpt" | head -1)
    FP_ERRORS=$(grep -oP 'Found\s+\K[0-9]+(?=\s+Footprint errors)' "$TEMP_DIR/drc_report.rpt" | head -1)
    ERROR_COUNT=$(grep -c '; error' "$TEMP_DIR/drc_report.rpt" || true)

    if [ "${UNCONNECTED:-0}" -gt 0 ] || [ "${FP_ERRORS:-0}" -gt 0 ] || [ "$ERROR_COUNT" -gt 0 ]; then
        echo -e "${RED}  FAIL: DRC errors (unconnected: ${UNCONNECTED:-0}, footprint: ${FP_ERRORS:-0}, violations: $ERROR_COUNT)${NC}"
        FAILED=1
    else
        WARNINGS=$(grep -oP 'Found\s+\K[0-9]+(?=\s+DRC violations)' "$TEMP_DIR/drc_report.rpt" | head -1)
        echo -e "${GREEN}  PASS: DRC (0 errors, ${WARNINGS:-0} warnings)${NC}"
    fi
else
    echo -e "${RED}  FAIL: DRC report not generated${NC}"
    FAILED=1
fi

# --- BOM ---
echo -e "\n${YELLOW}[3/4] Exporting BOM...${NC}"
"$KICAD_CLI" sch export bom \
    --output "$TEMP_DIR/bom_check.csv" \
    "$KICAD_SCH" 2>/dev/null

if [ -s "$TEMP_DIR/bom_check.csv" ]; then
    LINES=$(wc -l < "$TEMP_DIR/bom_check.csv")
    echo -e "${GREEN}  PASS: BOM exported ($LINES lines)${NC}"
else
    echo -e "${RED}  FAIL: BOM export failed${NC}"
    FAILED=1
fi

# --- Netlist validation (STM32 datasheet rules) ---
echo -e "\n${YELLOW}[4/4] Running netlist validation (STM32 datasheet rules)...${NC}"
"$KICAD_CLI" sch export netlist \
    --output "$TEMP_DIR/netlist.net" \
    "$KICAD_SCH" 2>/dev/null

if [ -s "$TEMP_DIR/netlist.net" ]; then
    if python3 kibot_resources/scripts/validate_netlist.py \
        -n "$TEMP_DIR/netlist.net" \
        -o "$TEMP_DIR" 2>/dev/null; then
        echo -e "${GREEN}  PASS: Netlist validation${NC}"
    else
        echo -e "${RED}  FAIL: Netlist validation found errors${NC}"
        echo -e "${RED}  Check $TEMP_DIR/validation_report.txt for details${NC}"
        FAILED=1
    fi
else
    echo -e "${RED}  FAIL: Netlist export failed${NC}"
    FAILED=1
fi

# --- Result ---
echo ""
if [ "$FAILED" -gt 0 ]; then
    echo -e "${RED}=== PUSH BLOCKED: Fix the errors above before pushing ===${NC}"
    echo -e "${RED}Reports saved in $TEMP_DIR/${NC}"
    exit 1
else
    echo -e "${GREEN}=== All checks passed. Push allowed. ===${NC}"
    rm -rf "$TEMP_DIR"
    exit 0
fi
